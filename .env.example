# ShopWave Agent Environment Variables
# Copy this file to .env and fill in the values

# Ollama Settings (Local AI)
LLM_PROVIDER=ollama
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# Optional: Cloud API (if you want to switch back)
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

# Agent Strategy
SHOPWAVE_MAX_CONCURRENT=2
SHOPWAVE_LOG_LEVEL=INFO
